# Hive — 環境変数テンプレート。`cp .env.example .env` して値を埋める。
# 認証は gcloud の Application Default Credentials (ADC) を使用するため、ここに鍵は書かない。
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project <PROJECT_ID>

GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

HIVE_MODEL_FLASH=gemini-3.5-flash
HIVE_MODEL_PRO=gemini-3.1-pro-preview

# 公開デプロイ用のGoogle認証＋週間利用制限（Claude方式：個人上限＋全体安全弁）。
# HIVE_OAUTH_CLIENT_ID をセットした時だけ有効（ローカル開発では未設定のままでよい）。
# フロント側は NEXT_PUBLIC_GOOGLE_CLIENT_ID に同じ値をビルド時に渡す。
# カウンタの永続化には Firestore を使う（未設定環境ではメモリカウンタで代替）。
# HIVE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
# HIVE_WEEKLY_LIMIT=30            # 1ユーザの週間発注上限
# HIVE_GLOBAL_WEEKLY_LIMIT=300    # サービス全体の週間上限（コストの頭打ち）
# HIVE_ADMIN_EMAILS=you@gmail.com # 無制限にするメール（カンマ区切り）

# F-15 セキュリティ監査: 1=両層（既定） / pattern=決定論パターンのみ（LLM呼び出しなし・$0） / 0=無効
HIVE_SECURITY=1

# F-11 Model Armor 実行時防御: 1=有効（既定・未セットアップ環境では自動スキップ） / 0=無効
# 事前準備（1回だけ）: make armor-setup
HIVE_ARMOR=1
# Model Armor はリージョナルAPI（Vertexのlocationとは独立）
HIVE_ARMOR_LOCATION=us-central1
HIVE_ARMOR_TEMPLATE=hive-guard
