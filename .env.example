# Hive — 環境変数テンプレート。`cp .env.example .env` して値を埋める。
# 認証は gcloud の Application Default Credentials (ADC) を使用するため、ここに鍵は書かない。
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project <PROJECT_ID>

GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

HIVE_MODEL_FLASH=gemini-3.5-flash
HIVE_MODEL_PRO=gemini-3.1-pro-preview

# F-15 セキュリティ監査: 1=両層（既定） / pattern=決定論パターンのみ（LLM呼び出しなし・$0） / 0=無効
HIVE_SECURITY=1
